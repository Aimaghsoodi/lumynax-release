# Copy to .env (gitignored) and edit. 01-bootstrap.sh will generate this automatically.
SEARXNG_SECRET=          # 64 hex chars; openssl rand -hex 32
LUMYNAX_ADMIN_KEY=       # bootstrap generates "lx-admin-..."; never give to a customer
HF_TOKEN=                # read-only HF token; rotate if leaked
LUMYNAX_PUBLIC_HOST=     # e.g. api.lumynax.com — used in customer onboarding packs
